{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/contacts", "destination": "/contacts.html" },
    { "source": "/sequences", "destination": "/sequences.html" },
    { "source": "/unsubscribe", "destination": "/unsubscribe.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
